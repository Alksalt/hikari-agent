# --- Claude Agent SDK auth ---
# Get this via:  claude setup-token
# Uses your Max subscription's $200/mo Agent SDK quota.
# IMPORTANT: do NOT set ANTHROPIC_API_KEY at the same time — that would
# bill standard API rates instead of using the Max quota.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Telegram ---
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user ID — bot is locked to this single user
OWNER_TELEGRAM_ID=

# --- Photo gen (OpenRouter Flux) ---
# https://openrouter.ai/keys — used by tools/photos.py
OPENROUTER_API_KEY=

# --- Memory embeddings + voice STT ---
# Optional for embeddings (Hikari uses local fastembed by default).
# REQUIRED for voice notes (Phase 6) — used to transcribe inbound Telegram
# voice messages via the OpenAI Whisper API (~$0.006/min, ~$6/year for normal use).
# If absent, voice notes get a graceful "can't transcribe right now" reply.
OPENAI_API_KEY=

# --- Phase 3: security ---
# Daily $ cap across all sessions (chat + dispatched). Default 5.0.
HIKARI_DAILY_CAP_USD=5.0

# --- Phase 4: outbound specialists ---
# Google Workspace (drive/gmail/calendar/docs/sheets/slides). The MCP server
# uses OAuth USER credentials, not service-account — needed because personal
# @gmail.com can't be accessed via SA. Run scripts/setup_google_oauth.py
# once to mint these three values via the InstalledAppFlow browser dance.
# Caveat: refresh token expires every 7 days while the OAuth consent screen
# is in "Testing" mode (sensitive scopes); re-run the script when that
# happens, or publish the app for production tokens.
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REFRESH_TOKEN=

# Notion: internal integration token (notion.so/profile/integrations).
# Share only the 3-4 databases Hikari needs (reading list, tasks, roadmap, 0→Hero).
NOTION_TOKEN=

# --- Phase 7 / 14: cross-device sync (optional) ---
# Static service-token bearer for the external MCP server (mcp_external/). Used
# by Claude Code's `claude mcp add` and the Claude Desktop local config (i.e.
# anywhere you can paste a bearer). Generate via:
#   openssl rand -hex 32
# Then set mcp_external.enabled: true in config/engagement.yaml and run:
#   uv run python -m mcp_external.launch
# See scripts/install_cloudflared.md for the Cloudflare Tunnel setup that
# fronts this server.
HIKARI_MCP_SECRET=

# Phase 14: passphrase that gates the /authorize consent form for OAuth 2.1
# Custom Connectors (claude.ai web, iPhone). Generate with:
#   openssl rand -base64 24
# Without this set, OAuth-add-connector flows fail at the consent step (bearer
# path still works). At least one of HIKARI_MCP_SECRET / this var must be set
# for mcp_external to start.
HIKARI_OAUTH_OWNER_PASSPHRASE=

# Phase 14: optional dedicated signing key for the /authorize state cookie.
# If unset, derived deterministically from HIKARI_MCP_SECRET via HMAC, which is
# fine for a single-machine deployment. Generate with:
#   openssl rand -base64 32
# HIKARI_OAUTH_COOKIE_SECRET=

# --- Per-device paths (optional — auto-detected if unset) ---
# Root that dispatched Claude Code sessions are allowed to touch. Defaults to
# the parent of this repo (so sibling repos under the same agents/ folder are
# dispatchable without configuration). Override if you keep repos elsewhere.
# HIKARI_WORK_DIR=/Users/<you>/work_dir
#
# Obsidian vault path for the wiki tool. Defaults to the standard iCloud
# Obsidian location under your home folder. Override if your vault lives elsewhere.
# HIKARI_WIKI_VAULT=/Users/<you>/Library/Mobile Documents/iCloud~md~obsidian/Documents/alt-wiki
#
# SQLite DB file. Defaults to ./data/hikari.db beside the repo.
# HIKARI_DB_PATH=/absolute/path/to/hikari.db
#
# Engagement config override. Defaults to ./config/engagement.yaml.
# HIKARI_CONFIG_PATH=/absolute/path/to/engagement.yaml
#
# Generated-photo outbox dir for the Telegram bridge. Defaults to ./data/photo_outbox.
# HIKARI_PHOTO_OUTBOX=/absolute/path/to/photo_outbox

# --- Model selection (optional) ---
# Primary + fallback Claude models the agent runs on. Defaults below.
# HIKARI_MODEL=claude-sonnet-4-6
# HIKARI_MODEL_FALLBACK=claude-haiku-4-5

# --- Scheduler timezone (optional) ---
# Overrides scheduler.timezone in engagement.yaml (default Europe/Oslo). Use an
# IANA name. Affects daily_reflection / morning_brief cron firing time.
# HOME_TZ=Europe/Oslo

# --- Phase 10: morning weather brief ---
# Fallback when no recent Telegram location share is available.
# Recommended: your home coordinates.
HOME_LAT=
HOME_LON=

# Optional 3rd weather source. open-meteo + met.no work without keys; this
# adds OpenWeatherMap to the merge if you want a tie-breaker.
# OPENWEATHERMAP_API_KEY=

# --- Phase 10: translation ---
# DeepL Free: 500K char/month, register at https://www.deepl.com/pro-api
# If unset, translate tool falls back to LibreTranslate public endpoint.
DEEPL_API_KEY=

# --- Phase 10: YouTube Music ---
# Path to browser-cookie auth blob. See scripts/setup_ytmusic.md for the
# DevTools paste flow. Default is ./secrets/ytmusic_browser.json (gitignored).
YTMUSIC_BROWSER_JSON_PATH=

# --- Phase 11: MCP connectors ---
# Linear MCP — auth flows via OAuth on first use (no env var needed)

# GitHub MCP — Personal Access Token. Create at github.com/settings/tokens.
# Needs at least 'repo' + 'issues' scopes for read+write.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Playwright MCP — no auth needed

# Readwise MCP — single access token. Get at https://readwise.io/access_token.
# Mapped to ACCESS_TOKEN inside .mcp.json (what the upstream package expects).
READWISE_TOKEN=

# --- Observability via Logfire (optional, opt-in) ---
# Set HIKARI_LOGFIRE_ENABLED=1 to ship traces to Pydantic Logfire. Requires a
# LOGFIRE_TOKEN from https://logfire.pydantic.dev. Both unset = no telemetry.
# HIKARI_LOGFIRE_ENABLED=
# LOGFIRE_TOKEN=

# --- Tips ---
# Once you've migrated daemon-critical secrets to macOS Keychain via
# scripts/migrate_secrets_to_keychain.py, you can blank these out and run
# the agent from a .env.keychain shim that reads them via `security`.
